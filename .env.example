# Hermes-Agent智能客服系统环境变量配置模板
# 复制此文件为.env并填入实际值

# ========== API配置 ==========
# OpenRouter API密钥（支持多种LLM）
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx

# Anthropic API密钥（Claude模型）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# OpenAI API密钥（可选）
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# ========== 消息平台配置 ==========
# 飞书机器人配置（主要使用）
FEISHU_CUSTOMER_APP_ID=cli_a938ef04a579dccb
FEISHU_CUSTOMER_APP_SECRET=xxxxxxxxxxxxx

# Telegram Bot Token（可选）
TELEGRAM_BOT_TOKEN=xxxxxxxxxxxxx:xxxxxxxxxxxxx

# Discord Bot Token（可选）
DISCORD_BOT_TOKEN=xxxxxxxxxxxxx.xxxxx.xxxxxxxxxxxxx

# Discord Guild ID（服务器ID，可选）
DISCORD_GUILD_ID=123456789

# Slack App Token（可选）
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxxx

# Slack Bot Token（可选）
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxx

# Slack Signing Secret（可选）
SLACK_SIGNING_SECRET=xxxxxxxxxxxxx

# ========== 数据库配置 ==========
# 向量数据库路径
VECTOR_DB_PATH=./data/vectors

# 记忆数据库路径
MEMORY_DB_PATH=./data/memory

# 轨迹数据导出路径
TRAJECTORY_EXPORT_PATH=./data/trajectories

# ========== 安全配置 ==========
# 加密密钥（用于敏感数据加密）
ENCRYPTION_KEY=xxxxxxxxxxxxx

# JWT密钥
JWT_SECRET=xxxxxxxxxxxxx

# ========== 监控配置 ==========
# Prometheus指标端口
PROMETHEUS_PORT=9090

# 日志级别
LOG_LEVEL=INFO

# ========== Hermes配置 ==========
# Profile名称
HERMES_PROFILE=customer_service

# 工作目录
HERMES_WORKSPACE=./workspace/customer_service

# 最大并发子代理数
MAX_SUBAGENTS=3

# 技能生成触发阈值
SKILL_GENERATION_TRIGGER=15

# 技能优化间隔（秒）
SKILL_OPTIMIZATION_INTERVAL=3600

# ========== MCP服务器配置 ==========
# CRM系统MCP服务器URL
MCP_CRM_URL=https://crm.example.com/mcp

# 订单系统MCP服务器URL
MCP_ORDER_URL=https://order.example.com/mcp

# MCP认证客户端ID
MCP_CLIENT_ID=xxxxxxxxxxxxx

# MCP认证客户端密钥
MCP_CLIENT_SECRET=xxxxxxxxxxxxx
